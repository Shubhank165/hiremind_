GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=gemini-2.5-flash
TTS_MODEL=gemini-2.5-flash-preview-tts
GROQ_API_KEY=your-groq-api-key-here

# LLM provider
LLM_PROVIDER=groq
GROQ_LLM_MODEL=llama-3.1-8b-instant

# Voice providers
STT_PROVIDER=groq
STT_MODEL=whisper-large-v3-turbo
STT_LANGUAGE=en
TTS_PROVIDER=piper

# Local Piper CPU TTS
PIPER_BINARY=piper
PIPER_MODEL_PATH=models/piper/en_US-lessac-medium.onnx
PIPER_MODEL_CONFIG_PATH=models/piper/en_US-lessac-medium.onnx.json
PIPER_SPEAKER_ID=0
PIPER_NOISE_SCALE=0.667
PIPER_LENGTH_SCALE=1.0
PIPER_NOISE_W=0.8

# Gemini latency tuning
GEMINI_THINKING_BUDGET=0
GEMINI_TOP_P=0.9
GEMINI_TOP_K=20
GEMINI_JSON_MAX_TOKENS=900
GEMINI_TEXT_MAX_TOKENS=320

BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
BACKEND_URL=http://localhost:8000
CORS_ORIGINS=http://localhost:8501,http://127.0.0.1:8501
VOICE_SILENCE_SECONDS=1.1
VOICE_MIN_CHUNK_SECONDS=0.4
SESSION_STORE_ENABLED=true
SESSION_STORE_PATH=.session_store.json

# Profile extraction speed-up (true = skip LLM resume parsing)
FAST_PROFILE_MODE=true
CODE_EXECUTION_TIMEOUT=5
MAX_OUTPUT_LENGTH=10000
MAX_INTERVIEW_STEPS=12
MIN_INTERVIEW_STEPS=8
